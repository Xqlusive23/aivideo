# =============================================================================
# RunPod pod environment variables
# Location: RunPod console → Edit Pod → Environment Variables
#
# Copy each line into the RunPod UI (key = value).
# RTC_TICKET_SECRET must match ledger-backend/.env EXACTLY (full string, not truncated).
# VOICE_RT_URL in ledger must match this pod's public URL on port 8000.
# =============================================================================

RTC_TICKET_SECRET=your_secret_here_must_match_ledger_backend
VOICE_MODELS_DIR=/models
PORT=8000

# Expose HTTP ports in RunPod: 8000 (required), optionally 8888, 6006
# Mount network volume at: /models
# Public URL example: https://YOUR-POD-ID-8000.proxy.runpod.net
