# Copy to .env and fill in values:
#   copy .env.example .env
#
# FRONTEND ONLY — Vite reads VITE_* at build/dev time.
# See ledger-backend/.env.example for server secrets.

# Ledger API
VITE_LEDGER_BACKEND_URL=http://localhost:3002

# Decart video AI — https://decart.ai
VITE_DECART_API_KEY=

# RunPod voice-rt-server URL (same as ledger-backend VOICE_RT_URL)
VITE_VOICE_RT_URL=

# Hosted Windows installer URL (GitHub Release asset or CDN)
VITE_WINDOWS_DOWNLOAD_URL=https://github.com/Xqlusive23/aivideo/releases/download/v0.3.1/InspireTech.Setup.0.3.0.exe
