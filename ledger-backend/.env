# =============================================================================
# InspireTech — LEDGER BACKEND (Node.js API)
# Location: c:\Projects\aivideo\ledger-backend\.env
#
# Used when you run:  cd ledger-backend && npm start
#
# SERVER-ONLY SECRETS — never put these in the frontend .env or React code.
# After editing: restart ledger-backend.
# =============================================================================

PORT=3002
CREDITS_PER_SECOND=2

# --- Where the React app is hosted (CORS + Paystack redirect after checkout) ---
# Local dev:
FRONTEND_URL=http://localhost:5173
# Production (uncomment and use instead):
# FRONTEND_URL=https://yourdomain.com

# --- Paystack (https://dashboard.paystack.com → Settings → API Keys) ---
# Test key: sk_test_...   Live key: sk_live_... (after account activation)
PAYSTACK_SECRET_KEY=sk_test_9465314458795f777bf24a1249026d3074df8ff7

# --- Admin: mint customer access tokens (http://localhost:3002/admin.html) ---
# Generate new: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_SECRET=cb925ec039ce33826e3ba16de38c4c62ac00ebc4b3da7465

# --- ElevenLabs voice changer (chunk-based engine) ---
# From https://elevenlabs.io → Settings → API Keys
ELEVENLABS_API_KEY=sk_f3976a9244e5c559d9b5ffcbb27867cd1e738de1abcc34e0
# Optional model override (default is fine for most cases):
# ELEVENLABS_STS_MODEL_ID=eleven_english_sts_v2

# --- Real-time voice (RunPod voice-rt-server) ---
# RTC_TICKET_SECRET must match EXACTLY on the RunPod pod (see voice-rt-server/runpod.env.example)
RTC_TICKET_SECRET=6c6a64096b6458096b645d2af3079a916b3c7b714583d29c

# Public RunPod proxy URL (no trailing slash) — MUST match VITE_VOICE_RT_URL in project root .env
VOICE_RT_URL=https://9gnmghlas4m7ua-8000.proxy.runpod.net

# --- Optional ---
# DB_PATH=ledger.db
