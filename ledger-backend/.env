# From your Paystack Dashboard → Settings → API Keys & Webhooks.
# Use the TEST secret key (starts with sk_test_) until you're ready to go live
# (live keys start with sk_live_ and require your account to be activated).
PAYSTACK_SECRET_KEY=sk_test_9465314458795f777bf24a1249026d3074df8ff7

# Where your React app runs (Paystack redirects back here after checkout)
FRONTEND_URL=http://localhost:5173

PORT=3002
CREDITS_PER_SECOND=2

# NOTE on webhooks: unlike Stripe, Paystack has no local-forwarding CLI tool.
# Localhost URLs can't receive webhooks at all. For local dev, this backend
# relies on the /api/verify/:reference endpoint (called automatically when
# the frontend returns from checkout) instead — no public tunnel required.
# For production, you'll register a real webhook URL in the Paystack
# Dashboard (Settings → API Keys & Webhooks) pointing at your deployed
# backend's https://your-domain.com/api/webhooks/paystack — this is the
# reliability backstop in case a user closes the tab before returning.

