# =============================================================================
# InspireTech — FRONTEND (Vite / React / Windows desktop build)
# Location: c:\Projects\aivideo\.env
#
# Used when you run:  npm run dev
#                     npm run build
#                     npm run dist   (in aivideo-companion — bundles this app)
#
# After editing: restart `npm run dev`. Rebuild desktop app for .exe changes.
#
# SAFE TO EXPOSE IN BUNDLE: only VITE_* vars (they ship in the JS bundle).
# NEVER put Paystack, ElevenLabs, or ADMIN_SECRET here — those go in
# ledger-backend/.env only.
# =============================================================================

# --- Ledger API (credits, tokens, voice proxy, checkout) ---
# Local dev: http://localhost:3002
# Production: https://api.yourdomain.com
VITE_LEDGER_BACKEND_URL=http://localhost:3002

# --- Decart video AI (real-time face/body transformation) ---
# From https://decart.ai — ends up in the browser bundle; use a restricted key.
VITE_DECART_API_KEY=dct_chris_OZwlImwsVDnFCkkoHxTzIIbFZGEnMWVVfYsoTPSTPJTsJyHKXfYKvBmbkyfTvPyz

# --- Real-time voice (RunPod voice-rt-server public URL, no trailing slash) ---
# MUST be the same URL as VOICE_RT_URL in ledger-backend/.env
# Update both whenever you restart the RunPod pod and get a new proxy URL.
VITE_VOICE_RT_URL=https://9gnmghlas4m7ua-8000.proxy.runpod.net

# --- Landing page: Windows installer download link ---
# Leave empty until you upload InspireTech Setup.exe somewhere public.
# Example: https://github.com/you/inspiretech/releases/download/v0.3.0/InspireTech-Setup-0.3.0.exe
VITE_WINDOWS_DOWNLOAD_URL=
